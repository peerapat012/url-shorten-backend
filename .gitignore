# Dependency directories
node_modules/
jspm_packages/

# Build output
dist/
build/
out/

# Environment variables (CRITICAL: contains DB and Redis URLs)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Prisma
# Ignore the migrations if you want a fresh start each time, 
# but usually, you KEEP the migrations folder and ignore the SQLite DB if using one.
# Since you are using Postgres, we just ignore the environment files.
prisma/*.db
prisma/*.db-journal

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs
*.log

# OS Metadata
.DS_Store
Thumbs.db

# Editor/IDE folders
.vscode/
.idea/
*.swp
*.swo

# TypeScript
tsconfig.tsbuildinfo